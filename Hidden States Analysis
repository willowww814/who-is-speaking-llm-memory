# Step 2: Extracting Hidden States — BERT

import numpy as np
import torch
import random

def get_hidden_states(texts, tokenizer, model, batch_size=8):
    """
    Extract hidden states from all layers for a list of texts.
    Returns: array of shape (num_texts, num_layers+1, hidden_size)
    """
    all_hidden_states = []

    for i in range(0, len(texts), batch_size):
        batch = texts[i:i+batch_size]
        inputs = tokenizer(
            batch,
            return_tensors="pt",
            padding=True,
            truncation=True,
            max_length=128
        )

        with torch.no_grad():
            outputs = model(**inputs)

        # hidden_states: tuple of (num_layers+1) tensors
        # each tensor: (batch_size, seq_len, hidden_size)
        hidden_states = outputs.hidden_states  # 13 layers (embedding + 12)

        # Stack layers: (num_layers, batch_size, seq_len, hidden_size)
        stacked = torch.stack(hidden_states)

        # Mean pool over tokens: (num_layers, batch_size, hidden_size)
        pooled = stacked.mean(dim=2)

        # Transpose: (batch_size, num_layers, hidden_size)
        pooled = pooled.permute(1, 0, 2)

        all_hidden_states.append(pooled.numpy())

        if (i // batch_size) % 5 == 0:
            print(f"  Processed {min(i+batch_size, len(texts))}/{len(texts)}")

    return np.concatenate(all_hidden_states, axis=0)


