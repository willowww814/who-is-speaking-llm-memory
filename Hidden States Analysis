# Step 9: Layer-to-Layer Movement Analysis — Llama
#
# For each layer transition, calculate:
# 1. How much do personal sentences move?
# 2. How much do official sentences move?
# 3. Does the movement of personal sentences
#    bring them closer to or further from the official centroid?

import numpy as np

num_layers = p_hidden_llama.shape[1]  # 17

movement_analysis = []

for layer in range(1, num_layers):
    # Vector change between consecutive layers
    p_delta = p_hidden_llama[:, layer, :] - p_hidden_llama[:, layer-1, :]
    o_delta = o_hidden_llama[:, layer, :] - o_hidden_llama[:, layer-1, :]

    # Magnitude of movement
    p_movement = np.linalg.norm(p_delta, axis=1).mean()
    o_movement = np.linalg.norm(o_delta, axis=1).mean()

    # Direction: is personal moving toward or away from the official centroid?
    prev_dist = layer_distances_p_to_o_llama[layer-1]
    curr_dist = layer_distances_p_to_o_llama[layer]
    direction = curr_dist - prev_dist  # negative = closer, positive = further

    movement_analysis.append({
        'layer': layer,
        'p_movement': p_movement,
        'o_movement': o_movement,
        'ratio': p_movement / o_movement,  # >1 means personal moves more
        'direction': direction
    })

print("Layer | Personal Movement | Official Movement | "
      "Ratio (P/O) | Direction")
print("-" * 75)
for m in movement_analysis:
    dir_str = "← closer" if m['direction'] < 0 else "→ further"
    print(f"L{m['layer']:2d}   | {m['p_movement']:.4f}            | "
          f"{m['o_movement']:.4f}            | "
          f"{m['ratio']:.3f}      | {dir_str} ({m['direction']:+.4f})")

