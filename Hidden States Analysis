# Step 5: Extracting Hidden States — Llama

import numpy as np
import torch

def get_hidden_states_llama(texts, tokenizer, model, batch_size=4):
    """
    Extract hidden states from all layers for Llama.
    Returns: array of shape (num_texts, num_layers+1, hidden_size)
    """
    all_hidden_states = []

    for i in range(0, len(texts), batch_size):
        batch = texts[i:i+batch_size]
        inputs = tokenizer(
            batch,
            return_tensors="pt",
            padding=True,
            truncation=True,
            max_length=128
        ).to(model.device)

        with torch.no_grad():
            outputs = model(**inputs, output_hidden_states=True)

        hidden_states = outputs.hidden_states
        stacked = torch.stack(hidden_states)
        pooled = stacked.mean(dim=2)
        pooled = pooled.permute(1, 0, 2)

        all_hidden_states.append(pooled.cpu().float().numpy())

        if (i // batch_size) % 5 == 0:
            print(f"  Processed {min(i+batch_size, len(texts))}/{len(texts)}")

    return np.concatenate(all_hidden_states, axis=0)


