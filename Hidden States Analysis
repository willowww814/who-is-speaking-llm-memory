# Step 3: Layer-wise Cosine Distances to Corpus Centroids — BERT

import numpy as np
from numpy.linalg import norm

def cosine_dist(v1, v2):
    return 1 - np.dot(v1, v2) / (norm(v1) * norm(v2))

num_layers = p_hidden.shape[1]  # 13

# Compute centroid for each layer
p_centroids = p_hidden.mean(axis=0)  # (13, 768)
o_centroids = o_hidden.mean(axis=0)  # (13, 768)

layer_distances_p_to_o = []
layer_distances_p_to_p = []
layer_distances_o_to_o = []
layer_distances_o_to_p = []

for layer in range(num_layers):
    o_centroid = o_centroids[layer]
    p_centroid = p_centroids[layer]

    # Personal sentences: distance to official centroid, distance to personal centroid
    dists_p_to_o = [cosine_dist(p_hidden[i, layer], o_centroid)
                     for i in range(len(p_hidden))]
    dists_p_to_p = [cosine_dist(p_hidden[i, layer], p_centroid)
                     for i in range(len(p_hidden))]

    # Official sentences: distance to official centroid, distance to personal centroid
    dists_o_to_o = [cosine_dist(o_hidden[i, layer], o_centroid)
                     for i in range(len(o_hidden))]
    dists_o_to_p = [cosine_dist(o_hidden[i, layer], p_centroid)
                     for i in range(len(o_hidden))]

    layer_distances_p_to_o.append(np.mean(dists_p_to_o))
    layer_distances_p_to_p.append(np.mean(dists_p_to_p))
    layer_distances_o_to_o.append(np.mean(dists_o_to_o))
    layer_distances_o_to_p.append(np.mean(dists_o_to_p))

print("Layer | P→P    | P→O    | O→O    | O→P")
print("-" * 50)
for i in range(num_layers):
    layer_name = "Embed" if i == 0 else f"L{i:2d}"
    print(f"{layer_name} | "
          f"{layer_distances_p_to_p[i]:.4f} | "
          f"{layer_distances_p_to_o[i]:.4f} | "
          f"{layer_distances_o_to_o[i]:.4f} | "
          f"{layer_distances_o_to_p[i]:.4f}")

