# Step 5: Categorical Aggregation and Visualization of Semantic Drift

import matplotlib.pyplot as plt
import numpy as np

emotional_words = ["fear", "hope", "isolation", "safety", "death", "anxiety"]
social_words = ["family", "community", "home", "friends"]
medical_words = ["vaccines", "symptoms", "nurses", "hospitals", "individual", "pandemic"]

distances_dict_aligned = {w: d for w, d in distances_aligned}

def category_avg(words, distances_dict):
    scores = [distances_dict[w] for w in words if w in distances_dict]
    return sum(scores) / len(scores)

emotional_avg = category_avg(emotional_words, distances_dict_aligned)
social_avg = category_avg(social_words, distances_dict_aligned)
medical_avg = category_avg(medical_words, distances_dict_aligned)

print(f"Aligned average drift by category:")
print(f"\nEmotional/experiential words: {emotional_avg:.4f}")
for w in emotional_words:
    if w in distances_dict_aligned:
        print(f"  {w:15s}: {distances_dict_aligned[w]:.4f}")

print(f"\nSocial relational words:      {social_avg:.4f}")
for w in social_words:
    if w in distances_dict_aligned:
        print(f"  {w:15s}: {distances_dict_aligned[w]:.4f}")

print(f"\nMedical/technical words:      {medical_avg:.4f}")
for w in medical_words:
    if w in distances_dict_aligned:
        print(f"  {w:15s}: {distances_dict_aligned[w]:.4f}")

distances_sorted = sorted(distances_aligned, key=lambda x: x[1], reverse=True)
words = [w for w, d in distances_sorted]
vals = [d for w, d in distances_sorted]

colors = []
for w in words:
    if w in emotional_words:
        colors.append('#E74C3C')
    elif w in social_words:
        colors.append('#3498DB')
    elif w in medical_words:
        colors.append('#2ECC71')
    else:
        colors.append('#95A5A6')

fig, ax = plt.subplots(figsize=(12, 6))

bars = ax.barh(words, vals, color=colors, alpha=0.85)

for bar, val in zip(bars, vals):
    ax.text(val + 0.005, bar.get_y() + bar.get_height()/2,
            f'{val:.3f}', va='center', fontsize=9)

from matplotlib.patches import Patch
legend_elements = [
    Patch(facecolor='#E74C3C', label='Emotional/experiential'),
    Patch(facecolor='#3498DB', label='Social relational'),
    Patch(facecolor='#2ECC71', label='Medical/technical'),
]
ax.legend(handles=legend_elements, loc='lower right', fontsize=10)

ax.set_xlabel('Cosine Distance (aligned)', fontsize=11)
ax.set_title('Semantic Drift: Personal vs Official COVID-19 Discourse\n'
             '(cosine distance after Procrustes alignment)', fontsize=12)
ax.set_xlim(0, 1.0)
ax.axvline(x=0.5, color='gray', linestyle='--', alpha=0.5, linewidth=1)
ax.grid(axis='x', alpha=0.3)

plt.tight_layout()
plt.savefig('drift_distances_aligned.png', dpi=300, bbox_inches='tight')
plt.show()
print("Saved as drift_distances_aligned.png")
