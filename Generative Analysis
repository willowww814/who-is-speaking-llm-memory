# Step 1: Generative Experiment Setup — Building Context for Four Conditions
#
# Builds cleaned context passages from the personal (JOTPY) and official
# (WHO) corpora. The official corpus passages are stripped of timestamps
# and speaker codes before being used as context. Context size is capped
# at 40,000 characters per condition, the largest size allowed within
# API rate limits.

import re
import random
import json
import time
import os
import anthropic

# API key is read from the environment, never hardcoded.
# Set it beforehand with: export ANTHROPIC_API_KEY="your-key-here"
client = anthropic.Anthropic(api_key=os.environ["ANTHROPIC_API_KEY"])

def build_context_personal(filtered_text, max_chars=40000, seed=42):
    passages = []
    for entry in filtered_text.split('-' * 60):
        lines = entry.strip().split('\n')
        text = ' '.join([l for l in lines if '===' not in l]).strip()
        if len(text.split()) > 50:
            passages.append(text[:2000])
    random.seed(seed)
    random.shuffle(passages)
    context = ""
    for p in passages:
        if len(context) + len(p) < max_chars:
            context += p + "\n\n---\n\n"
        else:
            break
    return context

def build_context_official(filtered_text, max_chars=40000, seed=42):
    passages = []
    for entry in filtered_text.split('-' * 60):
        lines = entry.strip().split('\n')
        clean_lines = []
        for line in lines:
            line = line.strip()
            if not line:
                continue
            if '===' in line:
                continue
            if line.startswith('Source:'):
                continue
            if line.startswith('Download'):
                continue
            if re.match(r'^\d{2}:\d{2}:\d{2}', line):
                continue
            line = re.sub(r'^[A-Z]{2,4}\s{2,}', '', line).strip()
            if len(line) > 10:
                clean_lines.append(line)
        text = ' '.join(clean_lines).strip()
        if len(text.split()) > 50:
            passages.append(text[:2000])
    random.seed(seed)
    random.shuffle(passages)
    context = ""
    for p in passages:
        if len(context) + len(p) < max_chars:
            context += p + "\n\n---\n\n"
        else:
            break
    return context

