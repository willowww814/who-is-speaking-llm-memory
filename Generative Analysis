# Step 2: Generating Responses Across Four Conditions
#
# Three questions are each asked once per condition. 4 conditions x
# 3 questions = 9 responses total per condition's full pass through
# the question set (each question gets one response per condition).

QUESTIONS = [
    "What was COVID-19?",
    "What did it feel like to live through COVID-19?",
    "What was the greatest impact of COVID-19 on human life?"
]

def build_prompt(question, context):
    if context is None:
        return f"Answer the following question in 150-200 words:\n\n{question}"
    return f"""Based on the following source materials, answer this question in 150-200 words:

{question}

Source materials:
{context}"""

CONDITIONS = {
    "A_empty": {"name": "No context (free generation)", "context": None},
    "B_personal": {"name": "Personal corpus only (JOTPY)", "context": personal_ctx},
    "C_official": {"name": "Official corpus only (WHO)", "context": official_ctx},
    "D_mixed": {"name": "Mixed corpus (JOTPY + WHO)", "context": mixed_ctx}
}

results = {}
for cond_id, cond_info in CONDITIONS.items():
    print(f"\nGenerating: {cond_info['name']}")
    results[cond_id] = {"name": cond_info['name'], "responses": []}
    for q_idx, question in enumerate(QUESTIONS):
        print(f"  Q{q_idx+1}: {question[:40]}...")
        msg = client.messages.create(
            model="claude-haiku-4-5-20251001",
            max_tokens=400,
            messages=[{"role": "user",
                       "content": build_prompt(question, cond_info['context'])}]
        )
        results[cond_id]["responses"].append({
            "question": question,
            "response": msg.content[0].text
        })
        print(f"    done")
        time.sleep(5)

with open('rq2_four_conditions_v2.json', 'w', encoding='utf-8') as f:
    json.dump(results, f, ensure_ascii=False, indent=2)
print("\nDone! Saved to rq2_four_conditions_v2.json")

# Step 3: Encoding Generated Responses and Measuring Distance to Corpus Centroids

import json
import numpy as np
import torch
from numpy.linalg import norm

def encode_texts_llama(texts, tokenizer, model, batch_size=2):
    all_vecs = []
    for i in range(0, len(texts), batch_size):
        batch = texts[i:i+batch_size]
        inputs = tokenizer(
            batch,
            return_tensors="pt",
            truncation=True,
            max_length=512,
            padding=True
        ).to(model.device)
        with torch.no_grad():
            outputs = model(**inputs, output_hidden_states=True)
        vec = outputs.hidden_states[-1].mean(dim=1).cpu().float().numpy()
        all_vecs.extend(vec)
    return np.array(all_vecs)

def cosine_dist(v1, v2):
    return 1 - np.dot(v1, v2) / (norm(v1) * norm(v2))

